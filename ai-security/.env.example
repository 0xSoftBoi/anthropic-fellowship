# Copy to .env and fill in. Never commit the real .env.

# Required for the LLM analyzers (claude/agentic/hybrid) and patch generator.
ANTHROPIC_API_KEY=

# Optional — only needed to (re)fetch verified contract sources from Etherscan
# (benchmarks/fetch_contracts.py). Not needed to run the analyzers on contracts
# whose source is already present.
ETHERSCAN_API_KEY=
